# Copy this file to "agent.env" and fill in your free key to enable the
# natural-language Discord assistant. start.command loads agent.env automatically.
# Leave it unset and the app still runs free with the built-in keyword replies.

# Free Gemini key from https://aistudio.google.com/apikey  (no billing required)
export GOOGLE_API_KEY="paste-your-free-gemini-key-here"

# Optional: pick a free model (default: gemini-2.0-flash)
# export KNEECARE_MODEL="gemini-2.5-flash"
